<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
    <script src="js/theme-init.js"></script>
    <script src="js/app-version.js" defer></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PVE 多用户控制面板 | 登录</title>
