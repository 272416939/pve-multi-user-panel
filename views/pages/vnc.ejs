<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
    <script src="js/theme-init.js"></script>
    <script src="js/app-version.js" defer></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VNC 控制台</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #000;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        #toolbar {
            background: #1a1a2e;
            padding: 6px 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            flex-shrink: 0;
        }
        #toolbar .title { font-weight: 600; margin-right: auto; }
        #toolbar .status { font-size: 11px; color: #aaa; }
        #toolbar button {
            background: #e94560; color: #fff; border: none;
            padding: 5px 12px; border-radius: 3px; cursor: pointer; font-size: 12px;
            touch-action: manipulation;
        }
        #toolbar button:hover { background: #d63851; }
        #screen {
            flex: 1; display: flex; align-items: center;
            justify-content: center; position: relative; min-height: 0;
        }
        #screen canvas { display: block; }
        #connecting { color: #888; font-size: 14px; }
        .spinner {
            display: inline-block; width: 16px; height: 16px;
            border: 2px solid #555; border-top-color: #e94560;
            border-radius: 50%; animation: spin 0.8s linear infinite;
            vertical-align: middle; margin-right: 6px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .ctrl-bar {
            background: #16213e; padding: 6px 12px;
            flex-shrink: 0; display: flex; flex-wrap: wrap;
            gap: 4px; align-items: center;
        }
        .ctrl-bar .group-label {
            color: #666; font-size: 11px; margin: 0 4px;
            user-select: none;
        }
        .ctrl-bar button {
            background: #0f3460; color: #ddd; border: 1px solid #1a4a7a;
            padding: 4px 10px; border-radius: 3px; cursor: pointer;
            font-size: 11px; white-space: nowrap;
            touch-action: manipulation;
        }
        .ctrl-bar button:hover { background: #1a5a8a; color: #fff; }
        .ctrl-bar button.primary {
            background: #e94560; border-color: #e94560; color: #fff;
        }
        .ctrl-bar button.primary:hover { background: #d63851; }
        #error-msg { color: #e94560; }
        /* 剪贴板说明 modal */
        #clipboardModal {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.6); z-index: 100;
            justify-content: center; align-items: center;
        }
        #clipboardModal.show { display: flex; }
        #clipboardModal .modal-content {
            background: #1a1a2e; color: #d4d4d4; border: 1px solid #444;
            border-radius: 6px; padding: 20px 24px; max-width: 480px;
            font-family: Menlo, Monaco, "Courier New", monospace;
        }
        #clipboardModal h3 { margin-bottom: 12px; color: #fff; font-size: 15px; }
        #clipboardModal .clipboard-table { border-collapse: collapse; width: 100%; font-size: 12px; }
        #clipboardModal .clipboard-table th,
        #clipboardModal .clipboard-table td { padding: 6px 8px; text-align: left; border-bottom: 1px solid #333; }
        #clipboardModal .clipboard-table th { color: #888; font-weight: normal; }
        #clipboardModal kbd {
            background: #2a2a3e; border: 1px solid #555; border-radius: 3px;
            padding: 1px 6px; font-family: monospace; font-size: 11px; color: #fff;
        }
        #clipboardModal .clipboard-tip { margin-top: 12px; font-size: 11px; color: #888; line-height: 1.6; }
        #clipboardModal .modal-close { margin-top: 16px; text-align: right; }
        #clipboardModal .modal-close button {
            background: #444; color: #d4d4d4; border: none; padding: 6px 14px;
            border-radius: 3px; cursor: pointer; font-family: monospace; font-size: 12px;
        }
        #clipboardModal .modal-close button:hover { background: #555; }
    </style>
</head>
<body>
    <div id="toolbar">
        <span class="title"><span id="vmLabel"></span></span>
        <span class="status" id="statusText">连接中...</span>
        <button id="disconnectBtn" aria-label="断开连接">断开</button>
    </div>
    <div id="screen">
        <div id="connecting">
            <span class="spinner"></span>正在连接 VNC 控制台...
        </div>
    </div>
    <div class="ctrl-bar">
        <span class="group-label">系统</span>
        <button id="ctrlAltDelBtn" class="primary" aria-label="发送 Ctrl+Alt+Del">Ctrl+Alt+Del</button>
        <button id="winBtn" aria-label="发送 Win 键">⊞ Win</button>

        <span class="group-label">快捷键</span>
        <button id="altTabBtn" aria-label="发送 Alt+Tab">Alt+Tab</button>
        <button id="altF4Btn" aria-label="发送 Alt+F4">Alt+F4</button>
        <button id="winRBtn" aria-label="发送 Win+R">⊞+R 运行</button>
        <button id="winDBtn" aria-label="发送 Win+D">⊞+D 桌面</button>
        <button id="winEBtn" aria-label="发送 Win+E">⊞+E 资源管理器</button>
        <button id="ctrlShiftEscBtn" aria-label="发送 Ctrl+Shift+Esc">Ctrl+Shift+Esc</button>

        <span class="group-label">显示</span>
        <button id="fullscreenBtn" aria-label="切换全屏">全屏</button>
        <button id="scaleBtn" aria-label="切换缩放">适应窗口</button>

        <span class="group-label">剪贴板</span>
        <button id="clipboardHintBtn" aria-label="剪贴板使用说明">剪贴板 ?</button>
    </div>

    <div id="clipboardModal" role="dialog" aria-modal="true" aria-labelledby="clipboardTitle">
        <div class="modal-content">
            <h3 id="clipboardTitle">VNC 剪贴板使用说明</h3>
            <table class="clipboard-table">
                <thead><tr><th>快捷键</th><th>功能</th></tr></thead>
                <tbody>
                    <tr><td><kbd>Ctrl+Shift+C</kbd></td><td>复制 VM 剪贴板到浏览器</td></tr>
                    <tr><td><kbd>Ctrl+Insert</kbd></td><td>同上（兼容快捷键）</td></tr>
                    <tr><td><kbd>Ctrl+Shift+V</kbd></td><td>粘贴浏览器剪贴板到 VM</td></tr>
                    <tr><td><kbd>Shift+Insert</kbd></td><td>同上（兼容快捷键）</td></tr>
                </tbody>
            </table>
            <p class="clipboard-tip">
                提示：<br>
                • 在 VM 内 Ctrl+C 复制后，按 Ctrl+Shift+C 同步到浏览器剪贴板<br>
                • 浏览器复制后，按 Ctrl+Shift+V 粘贴到 VM<br>
                • 需 HTTPS 环境（navigator.clipboard API）<br>
                • 仅支持纯文本，不支持文件
            </p>
            <div class="modal-close">
                <button type="button" id="clipboardCloseBtn">关闭</button>
            </div>
        </div>
    </div>

    <script src="js/vnc-clipboard.js?_b=202607062300"></script>
    <script type="module" nonce="<%= cspNonce %>">
        import RFB from '/novnc/core/rfb.js';

        const error = <%- JSON.stringify(typeof error !== 'undefined' ? error : null) %>;
        if (error) {
            document.getElementById('statusText').textContent = error;
            document.getElementById('connecting').innerHTML = '<span id="error-msg">' + error + '</span>';
            throw new Error(error);
        }

        const ticket = <%- JSON.stringify(ticket) %>;
        const vmid = <%- JSON.stringify(vmid) %>;
        const type = <%- JSON.stringify(type) %>;
        const session = new URLSearchParams(location.search).get('session');

        const statusText = document.getElementById('statusText');
        const connectingEl = document.getElementById('connecting');
        const screenEl = document.getElementById('screen');
        document.getElementById('vmLabel').textContent = (type === 'lxc' ? 'CT ' : 'VM ') + vmid + ' - VNC 控制台';

        if (!session) {
            statusText.textContent = '参数缺失';
            connectingEl.innerHTML = '<span id="error-msg">缺少会话参数，请重新打开</span>';
            throw new Error('missing session');
        }

        const wsProto = location.protocol === 'https:' ? 'wss:' : 'ws:';
        const wsUrl = `${wsProto}//${location.host}/vnc-proxy?session=${encodeURIComponent(session)}`;

        let rfb = null;
        let scaled = true;
        const clipboardState = VncClipboard.createClipboardState();

        function onConnected() {
            statusText.innerHTML = '已连接';
            connectingEl.style.display = 'none';
            document.getElementById('disconnectBtn').textContent = '已连接';
        }

        function onDisconnected() {
            statusText.innerHTML = '已断开';
            rfb = null;
            document.getElementById('disconnectBtn').textContent = '断开';
        }

        function connectVnc() {
            connectingEl.style.display = '';
            statusText.textContent = '连接中...';
            try {
                rfb = new RFB(screenEl, wsUrl, {
                    credentials: { password: ticket }
                });
                rfb.addEventListener('connect', onConnected);
                rfb.addEventListener('disconnect', onDisconnected);
                rfb.addEventListener('clipboard', function(e) {
                    VncClipboard.handleVncClipboardEvent(clipboardState, e.detail);
                });
                rfb.scaleViewport = scaled;
                rfb.resizeSession = false;
            } catch(e) {
                var errorSpan = document.createElement('span');
                errorSpan.id = 'error-msg';
                errorSpan.textContent = '连接失败: ' + e.message;
                connectingEl.innerHTML = '';
                connectingEl.appendChild(errorSpan);
                statusText.textContent = '连接失败';
            }
        }

        document.getElementById('disconnectBtn').addEventListener('click', function() {
            if (rfb) { rfb.disconnect(); onDisconnected(); }
            else { connectVnc(); }
        });

        document.getElementById('ctrlAltDelBtn').addEventListener('click', function() {
            if (rfb) rfb.sendCtrlAltDel();
        });

        function sendKeys(keys) {
            if (!rfb) return;
            keys.forEach(function(k) { rfb.sendKey(k, null, true); });
            keys.slice().reverse().forEach(function(k) { rfb.sendKey(k, null, false); });
        }

        function getKeyCode(key) {
            var map = { 'Alt': 0xFFE9, 'Tab': 0xFF09, 'F4': 0xFF14, 'L_Win': 0xFFEB, 'R_Win': 0xFFEC, 'D': 0x64, 'E': 0x65, 'R': 0x72, 'Shift': 0xFFE1, 'ControlLeft': 0xFFE3, 'Escape': 0xFF1B };
            return map[key] || 0;
        }

        document.getElementById('altTabBtn').addEventListener('click', function() { sendKeys([getKeyCode('Alt'), getKeyCode('Tab')]); });
        document.getElementById('altF4Btn').addEventListener('click', function() { sendKeys([getKeyCode('Alt'), getKeyCode('F4')]); });
        document.getElementById('winRBtn').addEventListener('click', function() { sendKeys([getKeyCode('L_Win'), getKeyCode('R')]); });
        document.getElementById('winDBtn').addEventListener('click', function() { sendKeys([getKeyCode('L_Win'), getKeyCode('D')]); });
        document.getElementById('winEBtn').addEventListener('click', function() { sendKeys([getKeyCode('L_Win'), getKeyCode('E')]); });
        document.getElementById('ctrlShiftEscBtn').addEventListener('click', function() { sendKeys([getKeyCode('ControlLeft'), getKeyCode('Shift'), getKeyCode('Escape')]); });

        document.getElementById('fullscreenBtn').addEventListener('click', function() {
            if (document.fullscreenElement) { document.exitFullscreen(); }
            else { document.documentElement.requestFullscreen(); }
        });

        document.getElementById('scaleBtn').addEventListener('click', function() {
            scaled = !scaled;
            if (rfb) rfb.scaleViewport = scaled;
            this.textContent = scaled ? '原始大小' : '适应窗口';
        });

        // 剪贴板快捷键：全局监听 keydown，仅当 rfb 已连接时处理
        document.addEventListener('keydown', function(e) {
            if (rfb) {
                VncClipboard.handleVncClipboardKeydown(e, rfb, clipboardState, navigator.clipboard);
            }
        });

        // 剪贴板说明 modal
        var clipboardModal = document.getElementById('clipboardModal');
        document.getElementById('clipboardHintBtn').addEventListener('click', function() {
            clipboardModal.classList.add('show');
        });
        document.getElementById('clipboardCloseBtn').addEventListener('click', function() {
            clipboardModal.classList.remove('show');
        });
        clipboardModal.addEventListener('click', function(e) {
            if (e.target === clipboardModal) clipboardModal.classList.remove('show');
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && clipboardModal.classList.contains('show')) {
                clipboardModal.classList.remove('show');
            }
        });

        connectVnc();
    </script>
</body>
</html>
