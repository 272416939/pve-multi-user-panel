<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
    <script src="js/theme-init.js"></script>
    <script src="js/app-version.js" defer></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LXC 终端</title>
    <link rel="stylesheet" href="https://jsd.owoser.cn/npm/xterm@5.3.0/css/xterm.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #000; overflow: hidden; height: 100vh; }
        #terminal-container {
            position: fixed; top: 28px; bottom: 0; left: 0; right: 0;
            padding: 4px;
        }
        .status-bar {
            position: fixed; top: 0; left: 0; right: 0;
            background: #1a1a2e; color: #888; font-size: 12px;
            padding: 4px 12px; font-family: monospace;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 10;
            height: 28px;
        }
        .status-bar .error { color: #ff4444; }
        .status-bar .connected { color: #44ff44; }
        .status-bar-left { display: flex; align-items: center; gap: 12px; }
        .status-bar-right { display: flex; align-items: center; gap: 12px; }
        #shortcutsBtn {
            background: transparent; color: #888; border: 1px solid #444;
            padding: 2px 8px; font-size: 11px; font-family: monospace;
            cursor: pointer; border-radius: 3px;
        }
        #shortcutsBtn:hover { color: #d4d4d4; border-color: #888; }
        #shortcutsModal {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.6); z-index: 100;
            justify-content: center; align-items: center;
        }
        #shortcutsModal.show { display: flex; }
        #shortcutsModal .modal-content {
            background: #1a1a2e; color: #d4d4d4; border: 1px solid #444;
            border-radius: 6px; padding: 20px 24px; max-width: 520px;
            max-height: 80vh; overflow-y: auto;
            font-family: Menlo, Monaco, "Courier New", monospace;
        }
        #shortcutsModal h3 { margin-bottom: 12px; color: #fff; font-size: 15px; }
        #shortcutsModal .shortcuts-table { border-collapse: collapse; width: 100%; font-size: 12px; }
        #shortcutsModal .shortcuts-table th,
        #shortcutsModal .shortcuts-table td { padding: 6px 8px; text-align: left; border-bottom: 1px solid #333; }
        #shortcutsModal .shortcuts-table th { color: #888; font-weight: normal; }
        #shortcutsModal kbd {
            background: #2a2a3e; border: 1px solid #555; border-radius: 3px;
            padding: 1px 6px; font-family: monospace; font-size: 11px; color: #fff;
        }
        #shortcutsModal .shortcuts-tip { margin-top: 12px; font-size: 11px; color: #888; }
        #shortcutsModal .modal-close {
            margin-top: 16px; text-align: right;
        }
        #shortcutsModal .modal-close button {
            background: #444; color: #d4d4d4; border: none; padding: 6px 14px;
            border-radius: 3px; cursor: pointer; font-family: monospace; font-size: 12px;
        }
        #shortcutsModal .modal-close button:hover { background: #555; }
    </style>
</head>
<body>
    <div id="terminal-container"></div>
    <div class="status-bar" id="statusBar">
        <div class="status-bar-left">
            <span id="statusText">正在连接...</span>
        </div>
        <div class="status-bar-right">
            <button id="shortcutsBtn" type="button" title="查看快捷键说明">快捷键 ?</button>
            <span id="connInfo">CT <%= locals.vmid %></span>
        </div>
    </div>
    <div id="shortcutsModal" role="dialog" aria-modal="true" aria-labelledby="shortcutsTitle">
        <div class="modal-content">
            <!-- 快捷键说明内容由 terminal-shortcuts-help.js 动态注入 -->
            <div id="shortcutsContent"></div>
            <div class="modal-close">
                <button type="button" id="shortcutsCloseBtn">关闭</button>
            </div>
        </div>
    </div>

    <script src="https://jsd.owoser.cn/npm/xterm@5.3.0/lib/xterm.min.js"></script>
    <script src="https://jsd.owoser.cn/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js"></script>
    <script src="js/terminal-keyboard.js?_b=202607062200"></script>
    <script src="js/terminal-shortcuts-help.js?_b=202607062200"></script>
    <script src="js/terminal-standalone.js?_b=202607062100"></script>
</body>
</html>
