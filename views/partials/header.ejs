<header class="page-header">
<style>@keyframes badge-breathe{0%,100%{box-shadow:0 0 6px rgba(239,68,68,.5),0 2px 8px rgba(0,0,0,.3)}50%{box-shadow:0 0 16px rgba(239,68,68,.75),0 3px 12px rgba(0,0,0,.35)}}</style>
    <div class="header-left">
        <button class="sidebar-toggle" id="sidebarToggleBtn" aria-label="菜单"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
        <span class="brand-logo"><%= locals.brandName || 'PVE 面板' %></span>
    </div>
    <div class="header-right">
        <% if (locals.showRefresh !== false) { %>
        <button class="header-btn" id="headerRefreshBtn" title="刷新"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg></button>
        <% } %>
        <button class="header-btn" id="themeToggle" title="切换主题" aria-label="切换主题">
            <svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <% if (locals.showMessages !== false) { %>
        <a href="user-center#messages" class="header-btn" title="消息" aria-label="消息">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="notification-badge" id="msgCount" style="display:none;position:absolute;top:-4px;right:-4px;min-width:18px;height:18px;padding:0 5px;border-radius:9px;background:linear-gradient(135deg,#ef4444,#f87171);color:#fff!important;font-size:11px;font-weight:700;line-height:18px;text-align:center;box-shadow:0 0 6px rgba(239,68,68,.5),0 2px 8px rgba(0,0,0,.3);animation:badge-breathe 2s ease-in-out infinite;z-index:10;">0</span>
        </a>
        <% } %>
        <div class="dropdown">
            <div class="user-info-dropdown" data-bs-toggle="dropdown">
                <img class="header-user-avatar" id="headerAvatar" alt="" />
                <span id="headerUsername">用户名</span>
            </div>
            <ul class="dropdown-menu dropdown-menu-end">
                <%# 此变量仅接受服务端可信 HTML，禁止传入用户可控数据 %>
                <%- locals.headerDropdownExtra || '' %>
                <li><a class="dropdown-item" href="user-center"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:text-bottom;margin-right:4px"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> 用户中心</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#" id="headerLogoutBtn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:text-bottom;margin-right:4px"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> 退出登录</a></li>
            </ul>
        </div>
    </div>
</header>