PORT=3002

JWT_SECRET=your-secret-key-change-this-in-production

SITE_URL=https://your-domain.com
# 网站域名（用于邮件中的链接），例如：https://pve.example.com
# 不设置时会自动使用当前请求的地址，但在反向代理（如宝塔）下可能获取到内网IP

# ============ 数据库配置（必填） ============
# 仅支持 MySQL 5.7+，不再支持 SQLite
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-database-name
MYSQL_CONNECTION_LIMIT=10       # 连接池最大连接数
MYSQL_QUEUE_LIMIT=0             # 排队上限（0=无限制）
MYSQL_ACQUIRE_TIMEOUT_MS=60000  # 获取连接超时(毫秒)

# ============ ikuai 软路由配置（必填） ============
# 用于：① DHCP 租约查询 → VM IP 自动获取
#       ② 端口映射 CRUD → 面板新增/编辑/删除转发时自动同步到路由器
#       ③ 接口列表查询 → 管理后台配置默认外网接口
IKUAI_HOST=http://your-ikuai-host
IKUAI_USER=your-ikuai-username
IKUAI_PASSWORD=your-ikuai-password

# 调试模式，开启后输出 extract-ips 等详细日志，设为 false 或留空则关闭
DEBUG=false

# GitHub 仓库地址（用于自动更新检查，海外环境回退）
GITHUB_REPO=272416939/pve-multi-user-panel

# Gitee 仓库地址（用于自动更新检查，国内优先）
GITEE_REPO=Allen0528/pve-multi-user-panel

# 默认管理员密码（可选，留空则首次启动时随机生成 16 位强密码并在控制台显示一次）
DEFAULT_ADMIN_PASSWORD=

# CORS 额外白名单（逗号分隔，如 https://example.com,https://api.example.com）
ALLOWED_ORIGINS=

# 服务器时区（默认 Asia/Shanghai）
TZ=Asia/Shanghai

# 运行环境（留空自动设为 production，启用模板缓存等优化）
# 开发调试时可设为 development，关闭模板缓存方便即时修改模板
# NODE_ENV=production
