PVE_HOST=https://192.168.1.100:8006
PVE_API_TOKEN=root@pam!panel=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PORT=3002

JWT_SECRET=your-secret-key-change-this-in-production

SITE_URL=https://your-domain.com
# 网站域名（用于邮件中的链接），例如：https://pve.example.com
# 不设置时会自动使用当前请求的地址，但在反向代理（如宝塔）下可能获取到内网IP

# ============ 数据库配置 ============
# 数据库类型: sqlite（默认，本地文件）| mysql（远程数据库）
# 切换为 MySQL 后需填写下方 MYSQL_* 配置项
DB_TYPE=sqlite

# MySQL 配置（仅 DB_TYPE=mysql 时生效，目标版本 MySQL 5.7+）
MYSQL_HOST=10.0.0.16
MYSQL_PORT=3306
MYSQL_USER=abtest
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=abtest
MYSQL_CONNECTION_LIMIT=10       # 连接池最大连接数
MYSQL_QUEUE_LIMIT=0             # 排队上限（0=无限制）
MYSQL_ACQUIRE_TIMEOUT_MS=60000  # 获取连接超时(毫秒)

# SSH 配置（用于 pct restore --force 1 覆盖恢复 LXC 容器）
PVE_SSH_HOST=192.168.1.100
PVE_SSH_PASSWORD=your-root-password

# ============ Redis 缓存配置（可选） ============
# 留空则禁用 Redis，所有缓存回退到进程内存
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=pve:

# ============ ikuai 软路由配置（必填） ============
# 用于：① DHCP 租约查询 → VM IP 自动获取
#       ② 端口映射 CRUD → 面板新增/编辑/删除转发时自动同步到路由器
#       ③ 接口列表查询 → 管理后台配置默认外网接口
IKUAI_HOST=http://10.10.10.1
IKUAI_USER=ikuai-username
IKUAI_PASSWORD=ikuai-password

# 调试模式，开启后输出 extract-ips 等详细日志，设为 false 或留空则关闭
DEBUG=false

# GitHub 仓库地址（用于自动更新检查，海外环境回退）
GITHUB_REPO=272416939/pve-multi-user-panel

# Gitee 仓库地址（用于自动更新检查，国内优先）
GITEE_REPO=Allen0528/pve-multi-user-panel
